# Database URL (Used for Prisma if you decide to use it, currently optional)
DATABASE_URL="file:./dev.db"

# JWT Secret for Admin Sessions
# Generate a strong random string for production
JWT_SECRET="your-super-secret-key-here"

# Firebase Project Configuration
# Found in Firebase Project Settings -> General
FIREBASE_PROJECT_ID="your-project-id"

# Firebase Service Account (Base64 Encoded JSON)
# To generate: 
# 1. Download your service account JSON from Firebase Console
# 2. Encode it: [System.Convert]::ToBase64String([System.IO.File]::ReadAllBytes("path/to/json"))
FIREBASE_SERVICE_ACCOUNT_KEY="your-base64-encoded-json-here"
